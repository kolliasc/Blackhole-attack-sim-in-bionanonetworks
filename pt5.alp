						</RecurrenceCode>
						<Condition><![CDATA[false]]></Condition>
					</Properties>
					<Action><![CDATA[for (int i = 0; i < moleculesPerPulse; i++) {
	if (transmitterType == 2){
    //double direction = uniform(360);
    //double distance = uniform(0, maxSpawnDistance);

    //double spawnX = getX() + distance * cos(toRadians(direction));
    //double spawnY = getY() + distance * sin(toRadians(direction));

    Molecule m = get_Main().add_molecules();
    m.jumpTo(getX(), getY());
    //m.setXY(spawnX, spawnY);
    //moleculesCreated = get_Main().molecules.size();
    moleculesCreated++;
    //m.heading = uniform(0,360);
    //m.broadcastEnabled = true;
    //m.brownianEnabled = true;
    //m.creationTime = time();
}
}
]]></Action>
				</Event>
				<Event>
					<Id>1758356886892</Id>
					<Name><![CDATA[emitChemotactics]]></Name>
					<X>50</X><Y>190</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Properties TriggerType="timeout" Mode="cyclic">
						<Timeout Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="TimeUnits"><![CDATA[SECOND]]></Unit>
						</Timeout>
						<Rate Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="RateUnits"><![CDATA[PER_SECOND]]></Unit>
						</Rate>
						<Id>1758356886890</Id>
						<OccurrenceAtTime>true</OccurrenceAtTime>
						<OccurrenceDate>1758441600000</OccurrenceDate>
						<OccurrenceTime Class="CodeUnitValue">
							<Code><![CDATA[2]]></Code>
							<Unit Class="TimeUnits"><![CDATA[SECOND]]></Unit>
						</OccurrenceTime>
						<RecurrenceCode Class="CodeUnitValue">
							<Code><![CDATA[200]]></Code>
							<Unit Class="TimeUnits"><![CDATA[SECOND]]></Unit>
						</RecurrenceCode>
						<Condition><![CDATA[false]]></Condition>
					</Properties>
					<Action><![CDATA[for (int i = 0; i < main.chemotacticsPerPulse + 100; i++) {
	if (transmitterType == 0){
	//positive chemos
		Chemotactic c = get_Main().add_chemotactics();
		c.type = 0;
		c.jumpTo(getX(), getY());
		}
	else if (transmitterType == 1)
	//negative chemos
		{
		Chemotactic c = get_Main().add_chemotactics();
		c.type = 1;
		c.oval.setFillColor(yellow);
		c.jumpTo(getX(), getY());
		}
	
}]]></Action>
				</Event>
