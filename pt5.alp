			<Functions>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1752485523479</Id>
					<Name><![CDATA[tumble]]></Name>
					<X>340</X><Y>110</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[//List<Chemotactic> nearbyChemotactics = agentsInRange(
//	main.chemotactics, chemotacticSensingRange);
ArrayList<Chemotactic> nearbyChemotactics = new ArrayList<>();

for (Chemotactic c : get_Main().chemotactics) {
    if (c == null) continue;

      double dxp = this.getX() - c.getX();
      double dyp = this.getY() - c.getY();
      double distSquared = dxp * dxp + dyp * dyp;

    if (distSquared <= chemotacticSensingRange) {
        nearbyChemotactics.add(c);
    }
}

double newHeading = uniform(0,360);
int positive = 0, negative = 0;

for (Chemotactic c : nearbyChemotactics) {
	if (c.type == 0) {
		positive += 1;
		//traceln("positive: " + positive);
	} else {
		negative += 1;
		//traceln("negative: " + negative);
	}
}

int currentConcentration = positive - negative;
//double newHeading = uniform(0, 30);  // default αν δεν υπάρχει επίδραση

if (currentConcentration == 0 && lastConcentration == 0) {
	runningMean = 1;  // no gradient → random motion
} else {
	runningMean = 4;  // under gradient

	Direction newDirection = chemotaxisDirection();

	if (currentConcentration >= lastConcentration) {
		// Προς μεγαλύτερη συγκέντρωση
		switch (newDirection) {
			case Beneficial: newHeading = heading; break;
			case Detrimental: newHeading = (heading + 180) % 360; break;
			case Left: newHeading = (heading + 270) % 360; break;
			case Right: newHeading = (heading + 90) % 360; break;
			//traceln("hello");
		}
	} else {
		// Προς χαμηλότερη συγκέντρωση
		switch (newDirection) {
			case Beneficial: newHeading = (heading + 180) % 360; break;
			case Detrimental: newHeading = heading; break;
			case Left: newHeading = (heading + 270) % 360; break;
			case Right: newHeading = (heading + 90) % 360; break;
		}
	}
	
	// Προσθήκη μικρής στοχαστικότητας
	newHeading = (newHeading + uniform(-15, 15)) % 360;
}

// Ενημέρωση κατεύθυνσης
heading = newHeading;
lastConcentration = currentConcentration;]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1758031098451</Id>
					<Name><![CDATA[move]]></Name>
					<X>340</X><Y>80</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[double curX = getX();
double curY = getY();
double newX = curX + cos(toRadians(heading));
double newY = curY + sin(toRadians(heading));

// === Έλεγχος ορίων ===
if (newX < get_Main().minX || newX > get_Main().maxX ||
    newY < get_Main().minY || newY > get_Main().maxY) {
    get_Main().remove_molecules(this);
    return;
}

// === Τελική μετακίνηση ===
moveTo(newX, newY);]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1758287806582</Id>
					<Name><![CDATA[collisions]]></Name>
					<X>410</X><Y>20</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[// Ορισμοί σταθερών
final double collisionRadius = 3.0;
final double collisionRadiusSquared = collisionRadius * collisionRadius;
final double tinyOffset = 1e-9;

// Προσδιορισμός θέσης στο spatial grid
int col = (int)((getX() - main.minX) / main.gridSize);
int row = (int)((getY() - main.minY) / main.gridSize);

// Υπολογισμός ταχύτητας από heading
double angleRad = Math.toRadians(this.heading);
double vx = Math.cos(angleRad);
double vy = Math.sin(angleRad);

// Έλεγχος γύρω από τα 3×3 γειτονικά κελιά
for (int dx = -1; dx <= 1; dx++) {
  int cx = col + dx;
  if (cx < 0 || cx >= main.cols) continue;

  for (int dy = -1; dy <= 1; dy++) {
    int cy = row + dy;
    if (cy < 0 || cy >= main.rows) continue;

    Main.Cell cell = main.spatialGrid[cx][cy];
    if (cell == null || cell.m == null) continue;
    for (Molecule other : cell.m) {
      if (other == this || other.isBound || this.getId() >= other.getId()) continue;

      double dxp = this.getX() - other.getX();
      double dyp = this.getY() - other.getY();
      double distSquared = dxp * dxp + dyp * dyp;

      if (distSquared >= collisionRadiusSquared) continue;

      // Debug / metric
      //main.totalMoleculeCollisions++;

      // Κανονικοποιημένο διανυσματικό separation
      double distance = Math.sqrt(distSquared);
      double invDist = 1.0 / (distance + tinyOffset);
      double nx = dxp * invDist;
      double ny = dyp * invDist;

      // Ταχύτητα του άλλου molecule
      double otherAngle = Math.toRadians(other.heading);
      double ux = Math.cos(otherAngle);
      double uy = Math.sin(otherAngle);

      // Σχετική ταχύτητα πάνω στη normal
      double relVx = vx - ux;
      double relVy = vy - uy;
      double relNormal = relVx * nx + relVy * ny;

      double overlap = collisionRadius - distance;
      double correction = 0.5 * (overlap + 1e-3); // Μικρή ώθηση να μην κολλήσουν

      if (relNormal > 0) {
        // Ήδη απομακρύνονται - κάνε μόνο separation
        this.setXY(getX() + nx * correction, getY() + ny * correction);
        other.setXY(other.getX() - nx * correction, other.getY() - ny * correction);
        continue;
      }

      // Ανταλλαγή normal συνιστωσών (ελαστική σύγκρουση)
      double impulseX = relNormal * nx;
      double impulseY = relNormal * ny;

      double newVx1 = vx - impulseX;
      double newVy1 = vy - impulseY;
      double newVx2 = ux + impulseX;
      double newVy2 = uy + impulseY;

      // Κανονικοποίηση για να διατηρηθεί σταθερό module
      double mag1 = Math.hypot(newVx1, newVy1);
      double mag2 = Math.hypot(newVx2, newVy2);
      if (mag1 > tinyOffset) {
        newVx1 /= mag1;
        newVy1 /= mag1;
      }
      if (mag2 > tinyOffset) {
        newVx2 /= mag2;
        newVy2 /= mag2;
      }

      // Ενημέρωση κατεύθυνσης
      this.heading = Math.toDegrees(Math.atan2(newVy1, newVx1));
      other.heading = Math.toDegrees(Math.atan2(newVy2, newVx2));

      // Separation
      this.setXY(getX() + nx * correction, getY() + ny * correction);
      other.setXY(other.getX() - nx * correction, other.getY() - ny * correction);

      // Ανανεώνουμε velocity για αυτό το frame
      angleRad = Math.toRadians(this.heading);
      vx = Math.cos(angleRad);
      vy = Math.sin(angleRad);
    }
  }
}
]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1758295666935</Id>
					<Name><![CDATA[collisionsChemoMol]]></Name>
					<X>410</X><Y>50</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[final double RB   = 2.0;   // ακτίνα Bacterium
final double RC   = 2.0;   // ακτίνα Chemotactic
final double RS   = 2.0;   // ακτίνα Sensor
final double RBC  = RB + RC;   // όριο επαφής Bacterium–Chemotactic
final double RBC2 = RBC * RBC; // στο τετράγωνο (έλεγχος χωρίς sqrt)
final double RBS  = RB + RS;   // όριο επαφής Bacterium–Sensor
final double RBS2 = RBS * RBS; // στο τετράγωνο
final double EPS  = 1e-3;      // μικρό push για να μη “κολλάνε”
final double ZEPS = 1e-9;      // προστασία από διαίρεση με μηδέν

// --- Σε ποιο κελί του grid βρίσκεται το Bacterium ---
int myCol = (int)((getX() - main.minX) / main.gridSize);
int myRow = (int)((getY() - main.minY) / main.gridSize);

// --- Cache διανύσματος ταχύτητας από το heading (μονάδα) ---
double hr  = Math.toRadians(this.heading);
double vbx = Math.cos(hr);
double vby = Math.sin(hr);

// === Σάρωση 3×3 γειτονικών κελιών στο spatial grid ===
for (int dx = -1; dx <= 1; dx++) {
  int col = myCol + dx;
  if (col < 0 || col >= main.cols) continue;

  for (int dy = -1; dy <= 1; dy++) {
    int row = myRow + dy;
    if (row < 0 || row >= main.rows) continue;

    Main.Cell cell = main.spatialGrid[col][row];
    if (cell == null) continue;

    // --- Bacterium ↔ Chemotactic ---
    if (cell.c != null) {
      for (int i = 0, n = cell.c.size(); i < n; i++) {
        Chemotactic ch = cell.c.get(i);
        if (ch == null) continue;

        // Απόσταση μεταξύ τους
        double dxp = this.getX() - ch.getX();
        double dyp = this.getY() - ch.getY();
        double d2  = dxp*dxp + dyp*dyp;
        if (d2 >= RBC2) continue; // δεν ακουμπάνε

        double d = Math.sqrt(d2);
        if (d < ZEPS) { 
          // Αν συνεπίπτονται → τυχαία μικρή μετατόπιση
          double a = uniform(0, 2*Math.PI);
          dxp = Math.cos(a); dyp = Math.sin(a); d = 1.0;
        }

        // Normal από Chemotactic προς Bacterium
        double invD = 1.0 / d;
        double nx   = dxp * invD;
        double ny   = dyp * invD;

        // 50/50 separation (push apart)
        double overlap = RBC - d;
        if (overlap > 0) {
          double half = 0.5 * (overlap + EPS);
          this.setXY(this.getX() + nx*half, this.getY() + ny*half);
          ch.setXY  (ch.getX() - nx*half,   ch.getY() - ny*half);
        }

        // Σχετικές ταχύτητες πάνω στη normal
        double chr = Math.toRadians(ch.heading);
        double vcx = Math.cos(chr), vcy = Math.sin(chr);
        double rvx = vbx - vcx,    rvy = vby - vcy;
        double vn  = rvx*nx + rvy*ny; // >0 = απομάκρυνση
        if (vn > 0) continue;         // αν απομακρύνονται, μόνο separation

        // Ελαστική ανταλλαγή normal συνιστωσών
        double jx  = vn*nx, jy = vn*ny;
        double nbx = vbx - jx, nby = vby - jy; // νέο διάνυσμα Bacterium
        double ncx = vcx + jx, ncy = vcy + jy; // νέο διάνυσμα Chemotactic

        // Κανονικοποίηση σε μέτρο=1
        double mb = Math.hypot(nbx, nby), mc = Math.hypot(ncx, ncy);
        if (mb > ZEPS) { nbx /= mb; nby /= mb; }
        if (mc > ZEPS) { ncx /= mc; ncy /= mc; }

        // Ενημέρωση headings
        this.heading = Math.toDegrees(Math.atan2(nby, nbx));
        ch.heading   = Math.toDegrees(Math.atan2(ncy, ncx));

        // Ανανέωση cache ταχύτητας Bacterium
        hr  = Math.toRadians(this.heading);
        vbx = Math.cos(hr); vby = Math.sin(hr);
      }
    }

    // --- Bacterium ↔ Sensor ---
    if (cell.s != null) {
      for (int i = 0, n = cell.s.size(); i < n; i++) {
        Sensor s = cell.s.get(i);
        if (s == null) continue;

        // Απόσταση
        double dxp = this.getX() - s.getX();
        double dyp = this.getY() - s.getY();
        double d2  = dxp*dxp + dyp*dyp;
        if (d2 >= RBS2) continue; // εκτός ακτίνας

        double d = Math.sqrt(d2);
        if (d < ZEPS) { 
          // Αν συνεπίπτονται → τυχαία μικρή μετατόπιση
          double a = uniform(0, 2*Math.PI);
          dxp = Math.cos(a); dyp = Math.sin(a); d = 1.0;
        }

        // Normal από Sensor προς Bacterium
        double invD = 1.0 / d;
        double nx   = dxp * invD;
        double ny   = dyp * invD;

        // 50/50 separation
        double overlap = RBS - d;
        if (overlap > 0) {
          double half = 0.5 * (overlap + EPS);
          this.setXY(this.getX() + nx*half, this.getY() + ny*half);
          s.setXY   (s.getX() - nx*half,    s.getY() - ny*half);
        }

        // Σχετικές ταχύτητες πάνω στη normal
        double sr = Math.toRadians(s.heading);
        double vsx = Math.cos(sr), vsy = Math.sin(sr);
        double rvx = vbx - vsx,    rvy = vby - vsy;
        double vn  = rvx*nx + rvy*ny;
        if (vn > 0) continue; // ήδη απομακρύνονται

        // Ελαστική ανταλλαγή normal συνιστωσών
        double jx  = vn*nx,  jy = vn*ny;
        double nbx = vbx - jx, nby = vby - jy; // νέο διάνυσμα Bacterium
        double nsx = vsx + jx, nsy = vsy + jy; // νέο διάνυσμα Sensor

        // Κανονικοποίηση
        double mb = Math.hypot(nbx, nby), ms = Math.hypot(nsx, nsy);
        if (mb > ZEPS) { nbx /= mb; nby /= mb; }
        if (ms > ZEPS) { nsx /= ms; nsy /= ms; }

        // Ενημέρωση headings
        this.heading = Math.toDegrees(Math.atan2(nby, nbx));
        s.heading    = Math.toDegrees(Math.atan2(nsy, nsx));

        // Ανανέωση cache ταχύτητας Bacterium
        hr  = Math.toRadians(this.heading);
        vbx = Math.cos(hr); vby = Math.sin(hr);
      }
    }
  }
}
]]></Body>
				</Function>
