						<Point><X>0</X><Y>0</Y></Point>
						<Point><X>-130</X><Y>-60</Y></Point>
					</Points>
					<IconOffset>20.0</IconOffset>
					<Properties Source="1752062451322" Target="1744822264681" Trigger="timeout">
						<Action><![CDATA[/*
double dist1=distanceTo(main.baseStation);
if ((dist1-1)> main.baseStation.sensingRadius)
{
if (main.receivers.get(1).numberofOCCUPIEDreceptorsB>0)
main.receivers.get(1).numberofOCCUPIEDreceptorsB--;
main.receivers.get(1).BacteriaAstonREC_B_for_report.remove(this);
main.receivers.get(1).collectionapobacteriaA.remove(this);
}
else
if (main.baseStation.numberofOCCUPIEDreceptorsBS>0)
{
main.baseStation.numberofOCCUPIEDreceptorsBS--;
main.baseStation.Exo_nodesA_for_report.remove(this);
main.baseStation.collectionapoA.remove(this);
}
killit=true;
*/
double distToReceiver = distanceTo(get_Main().receivers.get(0));

if ((distToReceiver - 1) > get_Main().receivers.get(0).sensingRadius) {

    // Αν είμαι εκτός sensing radius, ελευθερώνω υποδοχέα (αν είναι δεσμευμένος)
    if (get_Main().receivers.get(0).numberOfOccupiedReceptors > 0) {
        get_Main().receivers.get(0).numberOfOccupiedReceptors--;
    }

    // Αφαίρεση από συλλογές (αν υπάρχουν)
    get_Main().receivers.get(0).moleculesBoundToReceptors.remove(this);
    
}
// Σηματοδοτώ ότι το μόριο πρέπει να διαγραφεί
kill = true;
]]></Action>
