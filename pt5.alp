						<Id>1753799040372</Id>
						<OccurrenceAtTime>true</OccurrenceAtTime>
						<OccurrenceDate>1753862400000</OccurrenceDate>
						<OccurrenceTime Class="CodeUnitValue">
							<Code><![CDATA[0]]></Code>
							<Unit Class="TimeUnits"><![CDATA[SECOND]]></Unit>
						</OccurrenceTime>
						<RecurrenceCode Class="CodeUnitValue">
							<Code><![CDATA[0.03]]></Code>
							<Unit Class="TimeUnits"><![CDATA[SECOND]]></Unit>
						</RecurrenceCode>
						<Condition><![CDATA[false]]></Condition>
					</Properties>
					<Action><![CDATA[double timeNow = time();
double interval = 0.03;

if (timeNow > lastBindingTime + interval){
List<Molecule> nearbyMolecules = agentsInRange(get_Main().molecules, sensingRadius);

for (Molecule m : nearbyMolecules) {
    if (get_Main().receivers.get(0).numberOfOccupiedReceptors < get_Main().receivers.get(0).numberOfReceptors &&
        !get_Main().receivers.get(0).moleculesBoundToReceptors.contains(m)) {

        // Binding
        
        m.bindingTime = time();
        m.oval.setFillColor(red);

        get_Main().receivers.get(0).moleculesBoundToReceptors.add(m);
        get_Main().receivers.get(0).numberOfOccupiedReceptors++;
		m.stop_move_indicator = true;
        //traceln("BINDING molecule " + m.getIndex() + " at time " + time());
    }
}
}
]]></Action>
				</Event>
			</Events>
