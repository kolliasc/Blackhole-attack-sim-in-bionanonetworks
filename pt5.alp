					<Action><![CDATA[// === Καθαρισμός grid ===
/*for (int x = 0; x < cols; x++) {
    for (int y = 0; y < rows; y++) {
        if (spatialGrid[x][y] == null)
            spatialGrid[x][y] = new ArrayList<>();
        else
            spatialGrid[x][y].clear();
    }
}

// === Γέμισμα grid με Molecule ===
for (Molecule m : molecules) {
    int col = (int)((m.getX() - mX) / gridSize);
    int row = (int)((m.getY() - mY) / gridSize);

    if (col >= 0 && col < cols && row >= 0 && row < rows) {
        spatialGrid[col][row].add(m);
    }
}*/
/**
 * Αναδόμηση spatial grid σε κάθε tick.
 * Σκοπός: Ο(1) εύρεση γειτόνων με binning σε κελιά (gridSize).
 *
 * Ροή:
 * A) Καθαρισμός/εγγύηση ύπαρξης κελιών.
 * B) Τοποθέτηση Bacterium σε cell.b.
 * C) Τοποθέτηση Chemotactic σε cell.c.
 *
 * Σημειώσεις:
 * - Τα binded μπαίνουν κανονικά στο grid. Οι collision resolvers τα αγνοούν.
 * - Agents εκτός ορίων παραλείπονται (drop).
 * - Απαιτείται Cell με προδημιουργημένες λίστες: cell.b, cell.c.
 */
final double invGrid = 1.0 / gridSize;

// A) Καθαρισμός/εγγύηση κελιών
for (int x = 0; x < cols; x++) {
  for (int y = 0; y < rows; y++) {
    Main.Cell cell = spatialGrid[x][y];
    if (cell == null) {
      cell = new Main.Cell();
      spatialGrid[x][y] = cell;
    }
    cell.m.clear();   // λίστα Bacterium στο κελί
    cell.c.clear();   // λίστα Chemotactic στο κελί
  }
}

// B) Γέμισμα με Molecules
for (Molecule m : molecules) {
  int col = (int)((m.getX() - minX) * invGrid);
  int row = (int)((m.getY() - minY) * invGrid);
  if (col >= 0 && col < cols && row >= 0 && row < rows) {
    spatialGrid[col][row].m.add(m);
  }
}

// C) Γέμισμα με Chemotactic
for (Chemotactic ch : chemotactics) {
  int col = (int)((ch.getX() - minX) * invGrid);
  int row = (int)((ch.getY() - minY) * invGrid);
  if (col >= 0 && col < cols && row >= 0 && row < rows) {
    spatialGrid[col][row].c.add(ch);
  }
}

for (Sensor se : sensor) { // προσαρμόσε το όνομα συλλογής αν χρειάζεται
  int col = (int)((se.getX() - minX) * invGrid);
  int row = (int)((se.getY() - minY) * invGrid);
  if (col>=0 && col<cols && row>=0 && row<rows) {
  spatialGrid[col][row].s.add(se);
  }
}

]]></Action>
				</Event>
			</Events>
