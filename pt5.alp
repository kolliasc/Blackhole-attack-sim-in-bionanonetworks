					</Properties>
					<Action><![CDATA[/*double t = time();

// μόνο auto-rate
if (pulsePeriod > 0) return;

// === counts ===
double c1 = cpChemo();

double c2 = cpBact();
traceln(c1);
//traceln(c2);


// === peaks update ===
maxCpChemo = Math.max(maxCpChemo, c1);
maxCpBact  = Math.max(maxCpBact,  c2);
//traceln(maxCpChemo);
boolean chemoPeak = (maxCpChemo > 0) && (c1 <= maxCpChemo * (1 - dropFrac));
boolean bactPeak  = (maxCpBact  > 0) && (c2 <= maxCpBact  * (1 - dropFrac));

// lock chemo
if (chemoPeak && t - lastPeakTimeChemo >= refractory) {
  lastPeakTimeChemo = t;
  lastPeakCpChemo   = maxCpChemo;
  maxCpChemo = 0;
  //traceln("1");
}
// lock bact
if (bactPeak && t - lastPeakTimeBact >= refractory) {
  lastPeakTimeBact = t;
  lastPeakCpBact   = maxCpBact;
  maxCpBact = 0;
  //traceln("2");
}

// === decision if both peaks near in time ===
if (lastPeakTimeChemo > 0 && lastPeakTimeBact > 0 &&
    Math.abs(lastPeakTimeChemo - lastPeakTimeBact) <= coincideWindow) {

  double dChemo = (lastPeakCpChemo > 0)
    ? N_chemo / (lastPeakCpChemo * Math.sqrt(2 * Math.PI * Math.E))
    : Double.POSITIVE_INFINITY;
  double dBact = (lastPeakCpBact > 0)
    ? N_bact / (lastPeakCpBact * Math.sqrt(2 * Math.PI * Math.E))
    : Double.POSITIVE_INFINITY;

  // πιο εμφανές μήνυμα
  traceln("=== AUTO DECISION @t=" + String.format("%.1f", t) +
    " Sensor(" + (int)getX() + "," + (int)getY() + ")" +
    " dC=" + String.format("%.2f", dChemo) + " thrC=" + thrChemoDist +
    " dB=" + String.format("%.2f", dBact)  + " thrB=" + thrBactDist + " ===");

  if (dChemo < thrChemoDist && dBact < thrBactDist) {
    for (int i = 0; i < 100; i++) {
      Chemotactic neg = main.add_chemotactics();
      neg.type = 1; 
      neg.jumpTo(getX(), getY());
    }
    traceln("*** DEPLOYED NEG CHEMO @t=" + String.format("%.1f", t) +
      " Sensor(" + (int)getX() + "," + (int)getY() + ") ***");
  }

  // reset
  lastPeakTimeChemo = -1; lastPeakCpChemo = 0;
  lastPeakTimeBact  = -1; lastPeakCpBact  = 0;
}
*/
//double t = time();
//int negDeployCount = 0;
//int maxNegDeploy   = 1;



// μόνο auto-rate
//if (pulsePeriod > 0) return;


// debug
//traceln("t=" + String.format("%.1f", t)
  //+ " Sensor(" + (int)getX() + "," + (int)getY() + ")"
 // + " chemo=" + cChemo
 // + " bact=" + cBact
 // + " delta=" + delta);
 
double minDeltaChemo = 1;
// === μετρήσεις ===
double cChemo = cpChemo();
double cMol  = cpMolecules();
double delta = cChemo - cMol;

// === ΣΤΙΓΜΙΑΙΑ ΑΠΟΦΑΣΗ ===
if (!alreadyDeployed && (delta > minDeltaChemo)){
    //&& (negDeployCount < maxNegDeploy)) {

    //traceln("=== DEPLOY NEG CHEMO @t=" + String.format("%.1f", t)
    //  + " Sensor(" + (int)getX() + "," + (int)getY() + ")"
     // + " delta=" + delta + " ===");

    for (int i = 0; i < 50; i++) {
        Chemotactic neg = main.add_chemotactics(1);
        //neg.type = 1;   // negative
        neg.jumpTo(getX(), getY());
    }

    alreadyDeployed = true;
    //negDeployCount++;
}
]]></Action>
				</Event>
			</Events>
			<Functions>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1769018824662</Id>
					<Name><![CDATA[tumble]]></Name>
					<X>390</X><Y>60</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[ArrayList<Chemotactic> nearbyChemotactics = new ArrayList<>();

for (Chemotactic c : get_Main().chemotactics) {
    if (c == null) continue;

      double dxp = this.getX() - c.getX();
      double dyp = this.getY() - c.getY();
      double distSquared = dxp * dxp + dyp * dyp;

    if (distSquared <= chemotacticSensingRange) {
        nearbyChemotactics.add(c);
    }
}
//traceln("nearbyChemotactics = " + nearbyChemotactics.size());
double newHeading = uniform(0, 360);
int positive = 0, negative = 0;

for (Chemotactic c : nearbyChemotactics) {
	if (c.type == 0) {
		positive += 1;
		//traceln("positive: " + positive);
	} else {
		negative += 1;
		//traceln("negative: " + negative);
	}
}

int currentConcentration = positive - negative;
//double newHeading = uniform(0, 30);  // default αν δεν υπάρχει επίδραση

if (currentConcentration == 0 && lastConcentration == 0) {
	runningMean = 1;  // no gradient → random motion
} else {
	runningMean = 4;  // under gradient

	Direction newDirection = chemotaxisDirection();

	if (currentConcentration >= lastConcentration) {
		// Προς μεγαλύτερη συγκέντρωση
		switch (newDirection) {
			case Beneficial: newHeading = heading; break;
			case Detrimental: newHeading = (heading + 180) % 360; break;
			case Left: newHeading = (heading + 270) % 360; break;
			case Right: newHeading = (heading + 90) % 360; break;
			//traceln("hello");
		}
	} else {
		// Προς χαμηλότερη συγκέντρωση
		switch (newDirection) {
			case Beneficial: newHeading = (heading + 180) % 360; break;
			case Detrimental: newHeading = heading; break;
			case Left: newHeading = (heading + 270) % 360; break;
			case Right: newHeading = (heading + 90) % 360; break;
		}
	}
	
	// Προσθήκη μικρής στοχαστικότητας
	newHeading = (newHeading + uniform(-15, 15)) % 360;
}

// Ενημέρωση κατεύθυνσης
heading = newHeading;
lastConcentration = currentConcentration;
]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1769018832868</Id>
					<Name><![CDATA[move]]></Name>
					<X>390</X><Y>90</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[double curX = getX();
double curY = getY();
double newX = curX + cos(toRadians(heading));
double newY = curY + sin(toRadians(heading));

if (newX < get_Main().minX || newX > get_Main().maxX ||
    newY < get_Main().minY || newY > get_Main().maxY) {
    get_Main().remove_sensor(this);
    return;
}

moveTo(newX, newY);]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1769020031417</Id>
					<Name><![CDATA[collisions]]></Name>
					<X>520</X><Y>60</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[// --- Σταθερές για υπολογισμούς ---
final double R   = 3.0;     // απόσταση σύγκρουσης (κέντρο-σε-κέντρο)
final double R2  = R * R;   // ακτίνα² για έλεγχο χωρίς sqrt
final double EPS = 1e-3;    // μικρό έξτρα push για να μην κολλάνε
final double Z   = 1e-9;    // προστασία από διαίρεση με μηδέν

// --- Συντεταγμένες grid του αισθητήρα ---
int myCol = (int)((getX() - main.minX) / main.gridSize);
int myRow = (int)((getY() - main.minY) / main.gridSize);

// --- Cache διανύσματος ταχύτητας (από heading, μέτρο=1) ---
double hr  = Math.toRadians(this.heading);
double vax = Math.cos(hr), vay = Math.sin(hr);

// --- Σάρωση 3×3 κελιών γύρω μας ---
for (int dx = -1; dx <= 1; dx++) {
  int col = myCol + dx;
  if (col < 0 || col >= main.cols) continue;

  for (int dy = -1; dy <= 1; dy++) {
    int row = myRow + dy;
    if (row < 0 || row >= main.rows) continue;

    Main.Cell cell = main.spatialGrid[col][row];
    if (cell == null || cell.s == null) continue; // άδειο κελί ή χωρίς Sensors

    // --- Εξέταση όλων των Sensors στο κελί ---
    for (int i = 0, n = cell.s.size(); i < n; i++) {
      Sensor other = cell.s.get(i);
      if (other == null || other == this) continue;
      if (this.getId() >= other.getId()) continue; // κάθε ζευγάρι μόνο μία φορά

      // Υπολογισμός απόστασης
      double dxp = this.getX() - other.getX();
      double dyp = this.getY() - other.getY();
      double d2  = dxp*dxp + dyp*dyp;
      if (d2 >= R2) continue; // πολύ μακριά → skip

      double d = Math.sqrt(d2);
      if (d < Z) { // ίδια θέση → δώσε μικρό random offset για σταθερότητα
        double a = uniform(0, 2*Math.PI);
        dxp = Math.cos(a); dyp = Math.sin(a); d = 1.0;
      }

      // normal από τον other προς εμένα
      double invD = 1.0 / d;
      double nx   = dxp * invD;
      double ny   = dyp * invD;

      // Separation (50/50 απο-διείσδυση)
      double overlap = R - d;
      if (overlap > 0) {
        double half = 0.5 * (overlap + collisionTolerance);
        this.setXY (this.getX()  + nx*half, this.getY()  + ny*half);
        other.setXY(other.getX() - nx*half, other.getY() - ny*half);
      }

      // Ταχύτητα του other
      double orad = Math.toRadians(other.heading);
      double vbx  = Math.cos(orad), vby = Math.sin(orad);

      // Σχετική ταχύτητα στη normal
      double rvx = vax - vbx, rvy = vay - vby;
      double vn  = rvx*nx + rvy*ny;
      if (vn > 0) continue; // ήδη απομακρύνονται → skip αλλαγή κατεύθυνσης

      // Ελαστική ανταλλαγή normal συνιστωσών
      double jx  = vn*nx,  jy = vn*ny;
      double nax = vax - jx, nay = vay - jy; // νέο διάνυσμα self
      double nbx = vbx + jx, nby = vby + jy; // νέο διάνυσμα other

      // Κανονικοποίηση σε μονάδα
      double ma = Math.hypot(nax, nay), mb = Math.hypot(nbx, nby);
      if (ma > Z) { nax /= ma; nay /= ma; }
      if (mb > Z) { nbx /= mb; nby /= mb; }

      // Ενημέρωση headings
      this.heading  = Math.toDegrees(Math.atan2(nay, nax));
      other.heading = Math.toDegrees(Math.atan2(nby, nbx));

      // Update cache για τις επόμενες συγκρούσεις
      hr  = Math.toRadians(this.heading);
      vax = Math.cos(hr); vay = Math.sin(hr);
    }
  }
}
]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1769020061186</Id>
					<Name><![CDATA[chemoSensorCollisions]]></Name>
					<X>520</X><Y>80</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[final double RB   = 2.0;   // ακτίνα Bacterium
final double RC   = 2.0;   // ακτίνα Chemotactic
final double RS   = 2.0;   // ακτίνα Sensor
final double RBC  = RB + RC;
final double RBC2 = RBC * RBC;
final double RBS  = RB + RS;
final double RBS2 = RBS * RBS;
final double collisionTolerance  = 1e-3;  // μικρό push για σταθερότητα
final double ZEPS = 1e-9;  // αποφυγή /0

// --- κελί στο spatial grid του τρέχοντος Bacterium ---
// Χρησιμοποιούμε 3×3 γειτονιά για O(1) μέσο χρόνο ανά frame
int myCol = (int)((getX() - main.minX) / main.gridSize);
int myRow = (int)((getY() - main.minY) / main.gridSize);

// --- cache διανύσματος ταχύτητας από το heading (μονάδα) ---
// Αυτό αποφεύγει περιττές επανακλήσεις trigonometry σε κάθε ζεύγος
double hr  = Math.toRadians(this.heading);
double vbx = Math.cos(hr);
double vby = Math.sin(hr);

// === σάρωση 3×3 κελιών γύρω από το τρέχον κελί ===
// Επεξεργασία "επί τόπου" χωρίς προσωρινές συλλογές για λιγότερα allocs
for (int dx = -1; dx <= 1; dx++) {
  int col = myCol + dx;
  if (col < 0 || col >= main.cols) continue;

  for (int dy = -1; dy <= 1; dy++) {
    int row = myRow + dy;
    if (row < 0 || row >= main.rows) continue;

    Main.Cell cell = main.spatialGrid[col][row];
    if (cell == null) continue;

    // --- Bacterium ↔ Chemotactic ---
    // Για κάθε Chemo στο κελί: έλεγχος επικάλυψης, separation 50/50, μετά ελαστική σύγκρουση στην κανονική
    if (cell.c != null) {
      for (int i = 0, n = cell.c.size(); i < n; i++) {
        Chemotactic ch = cell.c.get(i);
        if (ch == null) continue;

        // διαφορά θέσης Bacterium - Chemotactic
        double dxp = this.getX() - ch.getX();
        double dyp = this.getY() - ch.getY();
        double d2  = dxp*dxp + dyp*dyp;
        if (d2 >= RBC2) continue;                  // εκτός ζώνης επαφής

        // απόσταση και ασφαλής normal
        double d    = Math.sqrt(d2);
        if (d < ZEPS) { // colocation: δώσε τυχαία μικρή κατεύθυνση για να "σπάσει" η συμμετρία
          double a = uniform(0, 2*Math.PI);
          dxp = Math.cos(a); dyp = Math.sin(a); d = 1.0;
        }
        double invD = 1.0 / d;
        double nx   = dxp * invD;                 // μονάδα normal Chemotactic→Bacterium
        double ny   = dyp * invD;

        // 50/50 separation: μετακινούμε και τα δύο μισό overlap + EPS
        double overlap = RBC - d;
        if (overlap > 0) {
          double half = 0.5 * (overlap + collisionTolerance);
          this.setXY(this.getX() + nx*half, this.getY() + ny*half);
          ch.setXY  (ch.getX() - nx*half,   ch.getY() - ny*half);
        }

        // σχετική ταχύτητα πάνω στην normal
        double chr = Math.toRadians(ch.heading);
        double vcx = Math.cos(chr), vcy = Math.sin(chr); // ταχύτητα Chemo (μονάδα)
        double rvx = vbx - vcx,    rvy = vby - vcy;      // σχετική ταχύτητα B - C
        double vn  = rvx*nx + rvy*ny;                    // προβολή στη normal
        if (vn > 0) continue; // ήδη απομακρύνονται → δεν απαιτείται ελαστική ανταλλαγή

        // ελαστική ανταλλαγή normal συνιστωσών (ίσα "μάζες", tangential παραμένει)
        double jx  = vn*nx,  jy = vn*ny;
        double nbx = vbx - jx, nby = vby - jy;    // νέα ταχύτητα Bacterium
        double ncx = vcx + jx, ncy = vcy + jy;    // νέα ταχύτητα Chemotactic

        // κανονικοποίηση σε μέτρο 1 για σταθερή κινητική "ενέργεια"
        double mb = Math.hypot(nbx, nby), mc = Math.hypot(ncx, ncy);
        if (mb > ZEPS) { nbx /= mb; nby /= mb; }
        if (mc > ZEPS) { ncx /= mc; ncy /= mc; }

        // ενημέρωση headings από τα νέα διανύσματα
        this.heading = Math.toDegrees(Math.atan2(nby, nbx));
        ch.heading   = Math.toDegrees(Math.atan2(ncy, ncx));

        // ανανέωση cache ταχύτητας B για τα επόμενα ζεύγη σε αυτό το frame
        hr  = Math.toRadians(this.heading);
        vbx = Math.cos(hr); vby = Math.sin(hr);
      }
    }

    // --- Bacterium ↔ Sensor ---
    // Ίδια λογική με Chemo: separation 50/50 + ελαστική ανταλλαγή στην normal
    if (cell.s != null) {
      for (int i = 0, n = cell.s.size(); i < n; i++) {
        Sensor s = cell.s.get(i);
        if (s == null) continue;

        double dxp = this.getX() - s.getX();
        double dyp = this.getY() - s.getY();
        double d2  = dxp*dxp + dyp*dyp;
        if (d2 >= RBS2) continue;                 // εκτός ζώνης επαφής

        double d    = Math.sqrt(d2);
        if (d < ZEPS) {                           // colocation safeguard
          double a = uniform(0, 2*Math.PI);
          dxp = Math.cos(a); dyp = Math.sin(a); d = 1.0;
        }
        double invD = 1.0 / d;
        double nx   = dxp * invD;                 // μονάδα normal Sensor→Bacterium
        double ny   = dyp * invD;

        // 50/50 separation με EPS
        double overlap = RBS - d;
        if (overlap > 0) {
          double half = 0.5 * (overlap + collisionTolerance);
          this.setXY(this.getX() + nx*half, this.getY() + ny*half);
          s.setXY   (s.getX() - nx*half,    s.getY() - ny*half);
        }

        // σχετική ταχύτητα πάνω στην normal
        double sr = Math.toRadians(s.heading);
        double vsx = Math.cos(sr), vsy = Math.sin(sr);   // ταχύτητα Sensor (μονάδα)
        double rvx = vbx - vsx,    rvy = vby - vsy;
        double vn  = rvx*nx + rvy*ny;
        if (vn > 0) continue; // ήδη απομακρύνονται

        // ελαστική ανταλλαγή normal συνιστωσών
        double jx  = vn*nx,  jy = vn*ny;
        double nbx = vbx - jx, nby = vby - jy;    // νέο για Bacterium
        double nsx = vsx + jx, nsy = vsy + jy;    // νέο για Sensor

        // κανονικοποίηση σε μέτρο 1
        double mb = Math.hypot(nbx, nby), ms = Math.hypot(nsx, nsy);
        if (mb > ZEPS) { nbx /= mb; nby /= mb; }
        if (ms > ZEPS) { nsx /= ms; nsy /= ms; }

        // headings από τα νέα διανύσματα
        this.heading = Math.toDegrees(Math.atan2(nby, nbx));
        s.heading    = Math.toDegrees(Math.atan2(nsy, nsx));

        // refresh cache για συνέπεια στα επόμενα ζεύγη
        hr  = Math.toRadians(this.heading);
        vbx = Math.cos(hr); vby = Math.sin(hr);
      }
    }
  }
}
]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1769020300666</Id>
					<Name><![CDATA[cpMolecules]]></Name>
					<X>390</X><Y>170</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[int count = 0;
  for (Molecule b : agentsInRange(main.molecules, sensingRadius))
    count++;
  return count;]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1769984944185</Id>
					<Name><![CDATA[cpChemo]]></Name>
					<X>390</X><Y>140</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[int count = 0;

double sx = getX();
double sy = getY();

for (Chemotactic c : main.chemotactics) {
    double dx = c.getX() - sx;
    double dy = c.getY() - sy;
    if (dx*dx + dy*dy <= sensingRadius*sensingRadius) {
        if (c.type == 0) count++;
    }
}

return count;]]></Body>
				</Function>
