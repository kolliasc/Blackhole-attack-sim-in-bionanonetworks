			<Functions>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1753362100189</Id>
					<Name><![CDATA[tumble]]></Name>
					<X>300</X><Y>210</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[heading = uniform(360);]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1753362101688</Id>
					<Name><![CDATA[move]]></Name>
					<X>300</X><Y>230</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[double curX = getX();
double curY = getY();
double newX = curX + cos(toRadians(heading));
double newY = curY + sin(toRadians(heading));

// === Έλεγχος ορίων ===
if (newX < get_Main().minX || newX > get_Main().maxX ||
    newY < get_Main().minY || newY > get_Main().maxY) {
    get_Main().remove_chemotactics(this);
    return;
}

// === Τελική μετακίνηση ===
moveTo(newX, newY);]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1758299136073</Id>
					<Name><![CDATA[collisions]]></Name>
					<X>300</X><Y>160</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[// === Σταθερές ===
final double rChem = 1.5;        // ακτίνα chemotactic
final double rThreshold = rChem * 2;
final double rThresholdSq = rThreshold * rThreshold;

final double smallPush = 1e-3;   // αποφυγή κολλήματος
final double minDist   = 1e-9;   // για αποφυγή διαίρεσης με μηδέν

// === Θέση στο grid ===
int thisCol = (int)((getX() - main.minX) / main.gridSize);
int thisRow = (int)((getY() - main.minY) / main.gridSize);

// === Διανυσματική ταχύτητα με βάση το heading ===
double theta = Math.toRadians(this.heading);
double vx = Math.cos(theta);
double vy = Math.sin(theta);

// === Σάρωση γύρω περιοχής στο grid (3×3 κελιά) ===
for (int dx = -1; dx <= 1; dx++) {
  int col = thisCol + dx;
  if (col < 0 || col >= main.cols) continue;

  for (int dy = -1; dy <= 1; dy++) {
    int row = thisRow + dy;
    if (row < 0 || row >= main.rows) continue;

    Main.Cell cell = main.spatialGrid[col][row];
    if (cell == null || cell.c == null) continue;

    for (Chemotactic other : cell.c) {
      if (other == null || other == this) continue;
      if (this.getId() >= other.getId()) continue; // κάθε ζευγάρι ελέγχεται 1 φορά

      // === Απόσταση ===
      double dxp = this.getX() - other.getX();
      double dyp = this.getY() - other.getY();
      double distSq = dxp * dxp + dyp * dyp;

      if (distSq >= rThresholdSq) continue; // δεν έχουν επικάλυψη

      double dist = Math.sqrt(distSq);
      if (dist < minDist) {
        // τα ίδια σημεία — δώσε μικρή τυχαία μετατόπιση
        double angle = uniform(0, 2 * Math.PI);
        dxp = Math.cos(angle);
        dyp = Math.sin(angle);
        dist = 1.0;
      }

      // === Normalized normal διάνυσμα ===
      double invDist = 1.0 / dist;
      double nx = dxp * invDist;
      double ny = dyp * invDist;

      // === Separation (αν υπάρχει επικάλυψη) ===
      double overlap = rThreshold - dist;
      if (overlap > 0) {
        double separation = 0.5 * (overlap + smallPush);
        this.setXY(getX() + nx * separation, getY() + ny * separation);
        other.setXY(other.getX() - nx * separation, other.getY() - ny * separation);
      }

      // === Ταχύτητα άλλου ===
      double otherRad = Math.toRadians(other.heading);
      double ox = Math.cos(otherRad);
      double oy = Math.sin(otherRad);

      // === Σχετική ταχύτητα πάνω στη normal ===
      double rvx = vx - ox;
      double rvy = vy - oy;
      double normalVel = rvx * nx + rvy * ny;

      if (normalVel > 0) continue; // αν απομακρύνονται, δεν αλλάζουμε headings

      // === Ανταλλαγή normal συνιστωσών (ελαστική σύγκρουση) ===
      double jx = normalVel * nx;
      double jy = normalVel * ny;

      double newVx = vx - jx;
      double newVy = vy - jy;
      double newOx = ox + jx;
      double newOy = oy + jy;

      // === Κανονικοποίηση ===
      double mag1 = Math.hypot(newVx, newVy);
      double mag2 = Math.hypot(newOx, newOy);

      if (mag1 > minDist) {
        newVx /= mag1;
        newVy /= mag1;
      }

      if (mag2 > minDist) {
        newOx /= mag2;
        newOy /= mag2;
      }

      // === Update headings ===
      this.heading = Math.toDegrees(Math.atan2(newVy, newVx));
      other.heading = Math.toDegrees(Math.atan2(newOy, newOx));

      // === Cache ανανέωση για το επόμενο ζευγάρι ===
      theta = Math.toRadians(this.heading);
      vx = Math.cos(theta);
      vy = Math.sin(theta);
    }
  }
}
]]></Body>
				</Function>
			</Functions>
