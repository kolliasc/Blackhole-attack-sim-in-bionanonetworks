					<Points>
						<Point><X>0</X><Y>0</Y></Point>
						<Point><X>0</X><Y>70</Y></Point>
					</Points>
					<Properties Target="1753361249392">
						<Action><![CDATA[// Ignore release chemotactic event until it is called
// release.reset();
// Don't absorb unless toggle is called
if (!get_Main().absorbMolecules) {
	absorbMolecules.restart(0);
}]]></Action>
					</Properties>	
				</StatechartElement>
			</StatechartElements>
			<Events>
				<Event>
					<Id>1753638378436</Id>
					<Name><![CDATA[absorbMolecules]]></Name>
					<X>200</X><Y>80</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Properties TriggerType="timeout" Mode="cyclic">
						<Timeout Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="TimeUnits"><![CDATA[SECOND]]></Unit>
						</Timeout>
						<Rate Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="RateUnits"><![CDATA[PER_SECOND]]></Unit>
						</Rate>
						<Id>1753638378434</Id>
						<OccurrenceAtTime>true</OccurrenceAtTime>
						<OccurrenceDate>1753689600000</OccurrenceDate>
						<OccurrenceTime Class="CodeUnitValue">
							<Code><![CDATA[0]]></Code>
							<Unit Class="TimeUnits"><![CDATA[SECOND]]></Unit>
						</OccurrenceTime>
						<RecurrenceCode Class="CodeUnitValue">
							<Code><![CDATA[0.5]]></Code>
							<Unit Class="TimeUnits"><![CDATA[SECOND]]></Unit>
						</RecurrenceCode>
						<Condition><![CDATA[false]]></Condition>
					</Properties>
					<Action><![CDATA[double currentTime = time();

List<Molecule> toAbsorb = new ArrayList<>();



for (Molecule m : get_Main().receivers.get(0).moleculesBoundToReceptors) {
    if (currentTime - m.bindingTime >= ligandResidenceTime) {
        toAbsorb.add(m);
    }
}

// Κάνε απορρόφηση
for (Molecule m : toAbsorb) {
    m.Absorbed = currentTime - m.creationTime;
    get_Main().Absorbed.add(m.Absorbed);
    
    get_Main().remove_molecules(m);
    get_Main().receivers.get(0).moleculesBoundToReceptors.remove(m);
    get_Main().receivers.get(0).numberOfOccupiedReceptors--;
}
absorbedMoleculesSinceLastReport += toAbsorb.size();]]></Action>
				</Event>
